# ──────────────────────────────────────────────────────────────────────────────
# SignalOS — Environment Variables
# Copy this file to .env.local for local dev, or .env.docker for Docker dev.
# Lines prefixed with # are optional or require an external service.
# ──────────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────────────────────────────
# For local dev (Postgres running on your machine):
#   DATABASE_URL=postgresql://postgres:password@localhost:5432/signalos
# For Docker Compose (set automatically by docker-compose.yml):
#   DATABASE_URL=postgresql://signalos:signalos@db:5432/signalos
DATABASE_URL=postgresql://postgres:password@localhost:5432/signalos
DIRECT_URL=postgresql://postgres:password@localhost:5432/signalos

# ── Redis (optional — app runs without it; enables dashboard caching) ─────────
# REDIS_URL=redis://localhost:6379

# ── Authentication (optional — app builds and runs without Clerk) ─────────────
# Get these from https://dashboard.clerk.com → your app → API Keys
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
# CLERK_SECRET_KEY=sk_test_...
# NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
# NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up

# ── Background Workers (optional — sync fallback works without Trigger.dev) ───
# Get this from https://cloud.trigger.dev → your project → API Keys
# TRIGGER_SECRET_KEY=tr_dev_...

# ── AI (optional — app runs with rule-based engine without OpenAI) ─────────────
# OPENAI_API_KEY=sk-proj-...
# NEXT_PUBLIC_OPENAI_ENABLED=true

# ── Observability (optional) ──────────────────────────────────────────────────
# NEXT_PUBLIC_POSTHOG_KEY=phc_...
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
# SENTRY_DSN=https://...

# ── API service ───────────────────────────────────────────────────────────────
# ALLOWED_ORIGINS=http://localhost:3000
# PORT=3001

# ── Email webhooks (optional) ─────────────────────────────────────────────────
# EMAIL_WEBHOOK_SECRET=your-secret-here
