# ══════════════════════════════════════════════════════════════════════════════
# SignalOS — unified environment template
#
# ▸ make dev   → copy this file to .env.local (localhost URLs, native apps)
# ▸ make up    → this file is used via .env.docker (Docker container URLs)
#
# All required values are pre-filled for local/Docker development.
# Uncomment optional sections to enable AI, workers, or observability.
# ══════════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────────
# For `make dev` (native): Postgres exposed on localhost:5433
# For `make up` (Docker):  Postgres accessed as "db:5432" inside containers
DATABASE_URL=postgresql://signalos:signalos@localhost:5433/signalos
DIRECT_URL=postgresql://signalos:signalos@localhost:5433/signalos

# ── Redis ─────────────────────────────────────────────────────────────────────
# For `make dev` (native): Redis exposed on localhost:6380
# For `make up` (Docker):  Redis accessed as "redis:6379" inside containers
REDIS_URL=redis://localhost:6380

# ── App URLs ──────────────────────────────────────────────────────────────────
# API URL seen by the browser (always localhost from the outside)
NEXT_PUBLIC_API_URL=http://localhost:3001
# CORS origins allowed by the API
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3008
PORT=3001

# ── Authentication seeds ──────────────────────────────────────────────────────
# Password used by `pnpm db:seed` to create all demo users.
# Login with any of: admin@signalos.vc / partner@signalos.vc / ops@signalos.vc
# All use this password.
SEED_PASSWORD=Password123!

# ── Email webhook security ────────────────────────────────────────────────────
# Required in production. An empty/dev value is fine locally.
EMAIL_WEBHOOK_SECRET=dev-local-secret

# ── Background workers (optional) ─────────────────────────────────────────────
# If absent, workflows run as inline server-action fallbacks.
# TRIGGER_SECRET_KEY=tr_dev_...

# ── AI (optional) ─────────────────────────────────────────────────────────────
# If absent, domain agents use deterministic rule-based logic (no API key needed).
# OPENAI_API_KEY=sk-proj-...
# NEXT_PUBLIC_OPENAI_ENABLED=false

# ── Live market intelligence (optional) ───────────────────────────────────────
# NEWS_API_KEY=

# ── Observability (optional) ──────────────────────────────────────────────────
# NEXT_PUBLIC_POSTHOG_KEY=
# NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
# SENTRY_DSN=
# SENTRY_AUTH_TOKEN=
