{
  "name": "signalos",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@9.15.4",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev --parallel",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "clean": "turbo run clean",
    "db:generate": "pnpm --filter @fundos/database generate",
    "db:migrate": "pnpm --filter @fundos/database migrate",
    "db:seed": "pnpm --filter @fundos/database seed",
    "db:studio": "pnpm --filter @fundos/database studio",
    "db:reset": "pnpm --filter @fundos/database reset"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.30.0",
    "@typescript-eslint/parser": "^8.30.0",
    "@vitest/ui": "^4.1.8",
    "eslint": "^8.57.0",
    "prettier": "^3.5.3",
    "turbo": "^2.3.3",
    "typescript": "^5.8.2",
    "vitest": "^4.1.8"
  }
}
