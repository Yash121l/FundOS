# SignalOS environment template
# Copy this file to .env.local for native development.
# Docker Compose also uses this template; compose overrides container-only URLs.

# Required for local development with `make dev`.
# `docker compose` exposes Postgres on localhost:5433 to avoid clashing with a
# local Postgres on 5432.
DATABASE_URL=postgresql://signalos:signalos@localhost:5433/signalos
DIRECT_URL=postgresql://signalos:signalos@localhost:5433/signalos

# Optional cache. The app works without Redis; with `make dev`, Redis is exposed
# on localhost:6380.
REDIS_URL=redis://localhost:6380

# App URLs
NEXT_PUBLIC_API_URL=http://localhost:3001
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3008
PORT=3001

# Authentication
# SignalOS uses local email/password auth for development. Seeded demo users are
# created by `pnpm db:seed`; see setup.md for credentials.

# Background workers (optional). If absent, development workflows use inline
# fallbacks where possible.
TRIGGER_SECRET_KEY=

# AI (optional). If absent, domain agents use deterministic rule-based logic.
OPENAI_API_KEY=
NEXT_PUBLIC_OPENAI_ENABLED=false

# Live market intelligence (optional).
NEWS_API_KEY=

# Email webhook security. Required in production. In development, an empty value
# allows local webhook testing.
EMAIL_WEBHOOK_SECRET=

# Observability (optional).
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
SENTRY_DSN=
SENTRY_AUTH_TOKEN=
