# ============================================================
# SignalOS — Web App Environment Variables
# ============================================================
# Copy this file to .env.local (gitignored) and fill in your values.
# The app builds and runs without most of these — see notes per section.

# ── Database (required) ──────────────────────────────────────
# Also set in packages/database/.env for the Prisma CLI (migrate, seed, studio).
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fundos"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/fundos"

# ── Authentication — Clerk (optional) ───────────────────────
# Without these the app runs in demo mode (no login required).
# Get keys at https://dashboard.clerk.com → API Keys
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/

# ── Background workers — Trigger.dev (optional) ──────────────
# Required to run background jobs in the cloud (AI analysis, trend detection,
# report generation, market signal ingestion).
# Falls back to inline execution when absent — no functionality lost.
# Get key at https://cloud.trigger.dev → Project → API Keys
TRIGGER_SECRET_KEY=tr_dev_...

# ── AI — OpenAI (optional) ───────────────────────────────────
# All AI agents fall back to deterministic rule-based logic when absent.
# Add this to enable real GPT-4o / GPT-4o-mini responses.
# Models: PortfolioAnalyst + TrendDetection + MarketIntel → gpt-4o-mini
#         LPReportingAgent → gpt-4o
# Get key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-...

# ── Live Market Intelligence — NewsAPI (optional) ────────────
# Required for the ingest-market-signals Trigger.dev job to pull live news.
# Without it, the job only enriches existing seeded signals (no live fetch).
# Free plan: 100 req/day, developer-only (not for production).
# Get key at https://newsapi.org/register
NEWS_API_KEY=

# ── Email Webhook — Inbound Founder Updates (optional) ───────
# Secures POST /api/webhooks/founder-update.
# The sending service must include: X-Webhook-Signature: sha256=<hmac-sha256 of body>
# Without this secret the endpoint accepts requests in development only.
# Supported providers: Postmark, SendGrid Inbound Parse, Mailgun Routes
EMAIL_WEBHOOK_SECRET=change-me-random-secret

# ── API URL (for internal references) ───────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3001

# ── Observability — Sentry (optional) ───────────────────────
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# ── Observability — PostHog (optional) ──────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
